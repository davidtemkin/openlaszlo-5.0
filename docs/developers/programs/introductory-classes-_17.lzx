<canvas height="75" width="100%">
  <script>
    var foo = new lz.view(canvas, {width: 50, height: 50, 
                                  x: 150, y: 0,
                                  bgcolor: 0,
                                  name: "myview"});
  </script>
  
  <button>Make window red
    <handler name="onclick">
      var nameOfView = "myview";
      canvas[nameOfView].setAttribute('bgcolor', 0xff0000);
    </handler>
  </button>
</canvas> 
