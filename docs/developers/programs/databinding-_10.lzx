
<canvas height="200" width="100%">
  
  <dataset name="mydset" src="resources/mydset.xml" type="http" request="true"/>
  
  <dataset name="week">
    <day>Sunday</day>
    <day>Monday</day>
    <day>Tuesday</day>
    <day>Wednesday</day>
    <day>Thursday</day>
    <day>Friday</day>
  </dataset>
  
  <script>
    Debug.debug("%w", mydset);
    Debug.debug("%w", canvas.datasets['mydset']);
    Debug.debug("%w", week)
  </script>
  </canvas>
