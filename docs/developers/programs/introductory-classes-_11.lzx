
<canvas width="100%" height="50" layout="y">
  <class name="mytext">
    <attribute name="text" type="html"/>
    <text text="${parent.text}"/>
  </class>
  <class name="myinputtext">
    <attribute name="text" type="html"/>
    <inputtext text="${parent.text}"/>
  </class>
  <mytext><i>styled</i> text</mytext>
  <myinputtext>plain text</myinputtext>
</canvas>
