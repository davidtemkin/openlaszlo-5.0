
<canvas height="400" width="100%">

    

    <dataset name="googleDset" />

    <soap name="google" wsdl="http://api.google.com/GoogleSearch.wsdl">
        <handler name="onload">
            Debug.debug('google soap service loaded');
        </handler>

        <handler name="onerror" args="error">
            Debug.error(error);
        </handler>
