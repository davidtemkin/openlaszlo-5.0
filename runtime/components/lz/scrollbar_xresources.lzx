<library>
    <resource name="lzscrollbar_xthumbleft_rsc" src="resources/scrollbar/scrollthumb_x_lft.png" />
    <resource name="lzscrollbar_xthumbmiddle_rsc" src="resources/scrollbar/scrollthumb_x_mid.png" />
    <resource name="lzscrollbar_xthumbright_rsc" src="resources/scrollbar/scrollthumb_x_rt.png" />
    <resource name="lzscrollbar_xthumbgripper_rsc" src="resources/scrollbar/thumb_x_gripper.png" />

    <resource name="lzscrollbar_xbuttonleft_rsc" >
        <frame src="resources/scrollbar/scrollbtn_x_lft_up.png" />
        <frame src="resources/scrollbar/scrollbtn_x_lft_mo.png" />
        <frame src="resources/scrollbar/scrollbtn_x_lft_dn.png" />
        <frame src="resources/scrollbar/scrollbtn_x_lft_dsbl.png" />
    </resource>
    <resource name="lzscrollbar_xbuttonright_rsc" >
        <frame src="resources/scrollbar/scrollbtn_x_rt_up.png" />
        <frame src="resources/scrollbar/scrollbtn_x_rt_mo.png" />
        <frame src="resources/scrollbar/scrollbtn_x_rt_dn.png" />
        <frame src="resources/scrollbar/scrollbtn_x_rt_dsbl.png" />
    </resource>
    <resource name="lzscrollbar_xtrack_rsc">
        <frame src="resources/scrollbar/x_scrolltrack.png"/>
        <frame src="resources/scrollbar/x_scrolltrack_dn.png"/>
        <frame src="resources/scrollbar/x_scrolltrack_dsbl.png"/>
    </resource>

</library>
