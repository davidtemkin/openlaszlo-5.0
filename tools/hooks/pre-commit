#!/bin/sh
# Auto-stamp the cache-busting BUILD_ID before each commit, so every deploy carries a
# build id that reflects the current platform (runtime + compiler bundle + shell + SW).
# See tools/stamp-version.mjs. Idempotent: only restages when the build id actually changed.
#
# Committed + shared (not the per-clone .git/hooks/ copy). Activate once per clone:
#   git config core.hooksPath tools/hooks
node tools/stamp-version.mjs || exit 0
git add service-worker.js startup/version.json 2>/dev/null
exit 0
