<canvas>
    <class name="thing" extends="view" width="40">
        <attribute name="n" value="3" type="number"/>
        <method name="bump" args="d">
            this.setAttribute('n', this.n + d);
        </method>
        <handler name="onclick">
            this.bump(1);
        </handler>
    </class>
    <thing x="${10 + 5}"/>
</canvas>
