{
  "name": "openlaszlo-compiler",
  "version": "5.0.0",
  "private": true,
  "type": "module",
  "description": "OpenLaszlo 5.0 LZX->DHTML compiler (TypeScript; byte-for-byte vs the original Java 4.9 oracle). Runs as a CLI, in Node, and in the browser.",
  "main": "./dist/index.js",
  "exports": {
    ".": "./dist/index.js",
    "./node": "./dist/node.js",
    "./browser": "./dist/browser.js"
  },
  "bin": {
    "lzc": "./dist/cli.js",
    "lzx-check": "./dist/lzx-check.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "bundle:browser": "npx esbuild dist/browser.js --bundle --format=esm --platform=browser --outfile=lzc-browser.js",
    "bundle:lzts": "npx esbuild dist/ts-carrier.js --bundle --format=esm --platform=browser --minify --outfile=../startup/lz-ts.js --define:process.env.NODE_ENV='\"production\"' --external:fs --external:path --external:os --external:inspector --external:perf_hooks --external:crypto --external:buffer --external:source-map-support",
    "dist": "npm run build && npm run bundle:browser && npm run bundle:lzts",
    "test": "npm run build && node --test test/*.test.mjs",
    "gen:lfcdts": "npm run build && node dist/lzx-check.js --write-lfc-dts > lfc.d.ts",
    "gen:shaderlib": "node scripts/gen-shaderlib-sources.mjs"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "esbuild": "^0.28.1",
    "typescript": "^5.9.3"
  }
}
